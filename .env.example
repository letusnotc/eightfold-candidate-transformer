# No API keys required for default setup.
# GLiNER and spaCy run fully locally.

# Optional: Gemini API key for LLM-based field mapping of unknown CSV/JSON columns
# Without it: alias map only (covers most common formats)
# With it: unknown field names are inferred by Gemini (temperature=0, deterministic)
# GEMINI_API_KEY=your_key_here

# Optional: GitHub personal access token (no scopes needed)
# Without it: 60 API requests/hour (hits limit fast with language-byte fetching)
# With it: 5,000 requests/hour
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Optional: point to a custom vLLM server instead of GLiNER
# VLLM_SERVER_URL=http://your-server/v1
# VLLM_MODEL=gemma-4

# Frontend API URL (set in Vercel environment variables)
NEXT_PUBLIC_API_URL=https://your-railway-app.up.railway.app
